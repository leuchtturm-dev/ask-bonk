{
  "name": "ask-bonk",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "build": "flue build --target cloudflare",
    "deploy": "BONK_VERSION=\"$(git describe --tags --always)\" BONK_COMMIT=\"$(git rev-parse --short HEAD)\" flue build --target cloudflare && wrangler deploy --config dist/ask_bonk/wrangler.json",
    "dev": "flue dev --target cloudflare",
    "test": "vitest",
    "cf-typegen": "wrangler types",
    "cli:build": "bun build cli/index.ts --compile --outfile cli/bonk",
    "cli": "bun run cli/index.ts",
    "lint": "oxlint",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@cloudflare/sandbox": "^0.7.21",
    "@flue/github": "^1.0.0-beta.1",
    "@flue/runtime": "^1.0.0-beta.1",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@opencode-ai/plugin": "^1.17.7",
    "@opencode-ai/sdk": "^1.17.7",
    "agents": "^0.14.1",
    "ai": "^6.0.205",
    "better-result": "^2.9.2",
    "hono": "4.12.22",
    "jose": "^6.2.3",
    "shescape": "^2.1.13",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@flue/cli": "^1.0.0-beta.1",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/node": "^25.9.3",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.9.3",
    "vitest": "~3.2.6",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "hono": "4.12.22"
  }
}
